# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Cartesia
CARTESIA_API_KEY=
CARTESIA_VERSION=2024-06-10
CARTESIA_MODEL_ID=sonic-3
CARTESIA_LANGUAGE=hi
CARTESIA_SPEED=0.95
CARTESIA_EMOTION=neutral

# Voice mapping (default for two speakers)
VOICE_ID_ANIKET=7dbf4710-0998-4b2c-bacb-9cb25cc68572
VOICE_ID_MALAY=85f9e4e0-8ae6-4c81-a88d-dbd80bbff29a

# Paths (defaults match your current repo)
ASSETS_GAMEPLAY_DIR=./youtube-videos-download/videos
ASSETS_AVATARS_DIR=./avatars
AVATAR_MAP_PATH=
RUNS_DIR=./runs
PROMPT_TEMPLATE_PATH=./ytautomation/prompts/script_prompt.txt

# Rendering
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
FPS=24
AUDIO_EXTENSION=wav
